# --- Supabase (from `supabase start`, or your hosted project settings) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — used by the Edge Function for server-side writes.
# This BYPASSES Row Level Security on purpose. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM provider: "mock" | "openai" | "mistral" ---
# "mock" lets you build and run the whole pipeline with no API key.
LLM_PROVIDER=mock
OPENAI_API_KEY=
MISTRAL_API_KEY=
